# =============================================================================
# GitLab 연동
# =============================================================================
# GitLab 인스턴스 URL (슬래시 없이)
VITE_GITLAB_URL=https://gitlab.example.com

# GitLab Personal Access Token (read_api 권한 필요)
# 발급: GitLab → Preferences → Access Tokens → read_api 체크
VITE_GITLAB_TOKEN=your_gitlab_personal_access_token

# =============================================================================
# Redmine 연동
# =============================================================================
# Redmine 인스턴스 URL (슬래시 없이)
VITE_REDMINE_URL=https://redmine.example.com

# Redmine API Access Key
# 발급: Redmine → 내 계정 → API 액세스 키
VITE_REDMINE_API_KEY=your_redmine_api_key

# =============================================================================
# Anthropic Claude AI
# =============================================================================
# Anthropic API Key
# 발급: https://console.anthropic.com → API Keys
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# 사용할 Claude 모델 ID
# 빠름/저렴: claude-haiku-4-5
# 정확/상세: claude-sonnet-4-6
VITE_CLAUDE_MODEL=claude-haiku-4-5

# =============================================================================
# 앱 동작 설정
# =============================================================================
# 자동 새로고침 간격 (초 단위)
# 0=수동, 300=5분, 900=15분, 1800=30분
VITE_DEFAULT_REFRESH_INTERVAL=900

# =============================================================================
# 데모 모드 (선택)
# =============================================================================
# true로 설정하면 API 키 없이 샘플 데이터로 전체 기능 체험 가능
# VITE_DEMO_MODE=true
